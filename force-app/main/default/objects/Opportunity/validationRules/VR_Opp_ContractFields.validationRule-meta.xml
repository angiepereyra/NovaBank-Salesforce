<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR_Opp_ContractFields</fullName>
    <active>true</active>
    <errorConditionFormula>AND(  ISPICKVAL(StageName, &quot;Contract&quot;),  OR(ISBLANK(PaymentDate__c), NOT(AtmWithdrawalEnabled__c)))</errorConditionFormula>
    <errorMessage>To move the Opportunity to the &apos;Contract&apos; stage, you must provide a Payment Date and ensure ATM Withdrawal is enabled</errorMessage>
</ValidationRule>
