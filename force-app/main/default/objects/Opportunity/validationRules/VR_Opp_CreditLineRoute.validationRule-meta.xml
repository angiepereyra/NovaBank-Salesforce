<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR_Opp_CreditLineRoute</fullName>
    <active>true</active>
    <errorConditionFormula>AND(  ISPICKVAL(StageName, &quot;Contract&quot;),  ISPICKVAL(PRIORVALUE(StageName), &quot;Start&quot;),  CreditLine__c &gt;= 3000)</errorConditionFormula>
    <errorMessage>Credit line ≥ 3000 must go through Evaluation.</errorMessage>
</ValidationRule>
